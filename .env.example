# API Platform — Environment Variables
# Copy to .env and fill in your values

# ─── PostgreSQL ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=api_platform
MAINBACKEND_DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/api_platform?sslmode=disable

# ─── Zitadel (Identity & Access Management) ───
ZITADEL_MASTERKEY=change-me-zitadel-masterkey-min-32-chars
ZITADEL_DB=zitadel
ZITADEL_OIDC_URL=https://auth.optamus.cloud
ZITADEL_OPENWEBUI_CLIENT_ID=openwebui@your-project
ZITADEL_OPENWEBUI_CLIENT_SECRET=change-me
ZITADEL_ADMIN_CLIENT_ID=admin-dashboard@your-project
ZITADEL_ADMIN_CLIENT_SECRET=change-me
MAINBACKEND_ZITADEL_CLIENT_ID=main-backend@your-project
MAINBACKEND_ZITADEL_CLIENT_SECRET=change-me

# ─── JWT ───
JWT_SECRET=change-me-jwt-secret-min-32-chars-long

# ─── OptamusUI ───
WEBUI_SECRET_KEY=change-me-webui-secret

# ─── Bifrost (AI Gateway) ───
BIFROST_LOG_LEVEL=info
# Bifrost internal URL (from MainBackend's perspective)
# BIFROST_BASE_URL=http://bifrost:8080

# ─── AI Provider Keys (for Bifrost) ───
# At least one of OPENAI_API_KEY or ANTHROPIC_API_KEY is required
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── CORS ───
CORS_ALLOW_ORIGIN=https://app.optamus.cloud;https://admin.optamus.cloud;https://optamus.cloud;https://www.optamus.cloud

# ─── Admin Dashboard ───
# API_BASE_URL defaults to relative path (empty) so the dashboard works
# behind any reverse proxy without hardcoded absolute URLs.
# Set explicitly only if the dashboard must call a different origin.
API_BASE_URL=
AUTH_BASE_URL=https://auth.optamus.cloud

# ─── Build ───
BUILD_HASH=dev
